# Local secrets template — copy to .env.local and fill in real values.
# .env.local is gitignored; never commit real keys.

# AI provider keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Current CORE v4 diagnostic model (Anthropic only today)
CORE_V4_MODEL=claude-sonnet-4-6

# Optional diagnostic controls (see docs/b5.2-core-v4-manual-json-diagnostic.md)
CORE_V4_APPROVE_AI=
CORE_V4_RENDER=
CORE_V4_FROM_JSON=
CORE_V4_OUT_DIR=
